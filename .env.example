# LexAI Desktop — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git!

# ── Server ──
PORT=3001
HOST=0.0.0.0

# ── Database ──
DATABASE_URL=postgresql://lexai:lexai_dev_password@localhost:5432/lexai

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Supabase Auth ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── Stripe ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PROFESSIONAL_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# ── Anthropic (Claude) ──
ANTHROPIC_API_KEY=

# ── DeepSeek ──
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── Kimi (Moonshot) ──
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1

# ── AWS S3 (document storage) ──
S3_BUCKET=lexai-documents
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT=  # leave empty for AWS, or set for S3-compatible storage

# ── Sentry ──
SENTRY_DSN=

# ── Desktop Release / Auto Update ──
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=
CSC_LINK=
CSC_KEY_PASSWORD=
WIN_CSC_LINK=
WIN_CSC_KEY_PASSWORD=

# ── JWT ──
JWT_SECRET=change-me-in-production

# ── Frontend (Electron) ──
VITE_API_BASE_URL=http://localhost:3001/v1

# ── Local inference sidecar (embedded runtime preferred; Ollama optional) ──
LOCAL_LLM_PROVIDER=embedded
LOCAL_LLM_AUTOSTART=false
LOCAL_LLM_EXECUTABLE_PATH=
LOCAL_LLM_ARGS=
LOCAL_LLM_BASE_URL=http://127.0.0.1:11435/v1
LOCAL_LLM_HEALTH_PATH=/health
LOCAL_LLM_MODEL=qwen2.5-7b-instruct-q4_k_m
LOCAL_LLM_MODEL_URL=
FREE_SEARCH_BASE_URL=
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
