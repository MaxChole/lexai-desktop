{
  "name": "lexai-desktop",
  "version": "0.1.0",
  "description": "LexAI Desktop — AI Legal Workbench",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "npm run build:main && npm run build:preload && electron .",
    "build:main": "tsc -p tsconfig.main.json && node -e \"require('fs').mkdirSync('dist/main',{recursive:true}); require('fs').writeFileSync('dist/main/package.json', JSON.stringify({type:'commonjs'}));\"",
    "build:preload": "tsc -p tsconfig.preload.json && node -e \"require('fs').mkdirSync('dist/preload',{recursive:true}); require('fs').writeFileSync('dist/preload/package.json', JSON.stringify({type:'commonjs'}));\"",
    "build": "npm run build:main && npm run build:preload && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "lexai",
    "legal-ai",
    "electron"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "electron-store": "^8.1.0",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.14"
  }
}
