{
  "name": "lexai-desktop",
  "version": "0.1.0",
  "description": "LexAI Desktop — AI Legal Workbench",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "cross-env NODE_ENV=development npm run build:main && cross-env NODE_ENV=development npm run build:preload && cross-env NODE_ENV=development electron .",
    "build:main": "tsc -p tsconfig.main.json && node -e \"require('fs').mkdirSync('dist/main',{recursive:true}); require('fs').writeFileSync('dist/main/package.json', JSON.stringify({type:'commonjs'}));\"",
    "build:preload": "tsc -p tsconfig.preload.json && node -e \"require('fs').mkdirSync('dist/preload',{recursive:true}); require('fs').writeFileSync('dist/preload/package.json', JSON.stringify({type:'commonjs'}));\"",
    "build": "npm run build:main && npm run build:preload && vite build",
    "dist": "npm run build && electron-builder --publish never",
    "dist:mac": "npm run build && electron-builder --mac dmg --universal --publish always",
    "dist:win": "npm run build && electron-builder --win nsis --x64 --publish always",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "lexai",
    "legal-ai",
    "electron"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.3.9",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@types/node": "^22.13.4",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.14"
  },
  "build": {
    "appId": "app.lexai.desktop",
    "productName": "LexAI Desktop",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "!node_modules/.cache/**/*"
    ],
    "extraMetadata": {
      "main": "dist/main/index.js"
    },
    "asar": true,
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.inherit.plist"
    },
    "dmg": {
      "artifactName": "LexAI-Desktop-${version}-mac-universal.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "LexAI-Desktop-${version}-win-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "MaxChole",
        "repo": "lexai-desktop"
      }
    ],
    "afterSign": "scripts/notarize.cjs"
  }
}
